# amiport.platesteel.net deployment config
# Copy to .env and fill in values. Never commit .env.

# SFTP/SSH deployment
DEPLOY_HOST=amiport.platesteel.net
DEPLOY_USER=amiport_platesteel
DEPLOY_PATH=/home/amiport_platesteel/amiport.platesteel.net
DEPLOY_PORT=22
DEPLOY_KEY=~/.ssh/amiport_deploy
DEPLOY_PASS=

# Site URL (used for manifest generation)
SITE_URL=http://amiport.platesteel.net

# MySQL database
DB_HOST=mysql-amiport.platesteel.net
DB_NAME=
DB_USER=
DB_PASS=

# Security
IP_SALT=
ADMIN_PASSWORD_HASH=
