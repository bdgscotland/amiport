# amiport.platesteel.net — server config
#
# Allow plain HTTP for amiget CLI (classic AmigaOS has no TLS).
# Browsers get HTTPS via Dreamhost's Let's Encrypt, but we don't force redirect.

# Do NOT force HTTPS — amiget CLI needs plain HTTP
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors off
    php_flag log_errors on
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType application/json "access plus 5 minutes"
    ExpiresByType application/octet-stream "access plus 1 day"
</IfModule>

# Prevent directory listing
Options -Indexes

# Rewrite rules:
#   1. amiga.html → amiga.php (internal rewrite, URL unchanged)
#      Dreamhost uses PHP-FPM — SetHandler/AddType for .html don't trigger FPM.
#      amiga.php is the authoritative PHP source; amiga.html stays for amiget URL compat.
#   2. Block data/ directory from public access
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^amiga\.html$ /amiga.php [L]
    RewriteRule ^data/ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
