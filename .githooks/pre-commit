#!/bin/bash
# pre-commit hook for amiport
# Validates documentation consistency and port directory hygiene before allowing commits.
#
# Install: git config core.hooksPath .githooks

set -e

echo "=== Pre-commit: checking documentation consistency ==="
make check-docs

echo "=== Pre-commit: checking port metadata consistency ==="
make check-port-metadata

echo "=== Pre-commit: checking for stray root files ==="
# Check for test/build artifacts that shouldn't be in the project root
STRAY=$(git diff --cached --name-only | grep -E '^(test_|gmon\.out|.*_native$|.*\.o$)' || true)
if [ -n "$STRAY" ]; then
    echo "BLOCKED: Stray files in project root:"
    echo "$STRAY"
    echo "All test/build artifacts must stay inside ports/<name>/."
    exit 1
fi

echo "=== Pre-commit: checking port directory hygiene ==="
# Verify no binaries in ported/ directories
PORTED_BINS=$(git diff --cached --name-only | grep -E 'ported/[^.]+$' | grep -v '\.[ch]$' || true)
if [ -n "$PORTED_BINS" ]; then
    echo "WARNING: Non-source files staged in ported/ directories:"
    echo "$PORTED_BINS"
    echo "Only .c and .h files should be in ported/. Binaries go in the port root."
    exit 1
fi

echo "=== Pre-commit: checking for non-ASCII in C source ==="
# bebbo-gcc silently corrupts output when it encounters UTF-8 multi-byte
# characters in .c/.h files, even inside comments. Functions vanish without
# any error. Only check staged ported/ and lib/ C source files.
NON_ASCII_FILES=""
for f in $(git diff --cached --name-only | grep -E '\.(c|h)$' | grep -E '^(ports/.*/ported/|lib/)'); do
    if [ -f "$f" ] && LC_ALL=C grep -Pn '[^\x00-\x7F]' "$f" > /dev/null 2>&1; then
        NON_ASCII_FILES="$NON_ASCII_FILES\n  $f: $(LC_ALL=C grep -Pn '[^\x00-\x7F]' "$f" | head -3)"
    fi
done
if [ -n "$NON_ASCII_FILES" ]; then
    echo "BLOCKED: Non-ASCII characters found in C source files:"
    echo -e "$NON_ASCII_FILES"
    echo ""
    echo "bebbo-gcc silently eats code around UTF-8 characters (even in comments)."
    echo "Replace: em-dash with --, arrow with ->, smart quotes with straight quotes."
    exit 1
fi

echo "=== Pre-commit: checking ARexx syntax ==="
# Check all .rexx files for non-ASCII, three-level compounds, and \= usage
if git diff --cached --name-only | grep -qE '\.rexx$'; then
    make check-arexx
fi

echo "=== Pre-commit: checking PORT.md enrichment ==="
# Block commits with placeholder PORT.md files (Phase 11b not completed)
PLACEHOLDER_PORTS=""
for portmd in $(git diff --cached --name-only | grep -E '^ports/[^/]+/PORT\.md$'); do
    if [ -f "$portmd" ] && grep -q '<!-- Populated by' "$portmd"; then
        PLACEHOLDER_PORTS="$PLACEHOLDER_PORTS\n  $portmd"
    fi
done
if [ -n "$PLACEHOLDER_PORTS" ]; then
    echo "BLOCKED: PORT.md files contain placeholder comments (Phase 11b not completed):"
    echo -e "$PLACEHOLDER_PORTS"
    echo ""
    echo "Run PORT.md enrichment before committing. Each PORT.md must have:"
    echo "  - Description (2-3 sentences, not one line)"
    echo "  - Portability Analysis table"
    echo "  - Transformations Applied table"
    echo "  - Build Configuration"
    echo "  - Test Results"
    exit 1
fi

echo "=== Pre-commit: checking catalog sync ==="
# site/data/catalog.json must match data/catalog.json
if [ -f "data/catalog.json" ] && [ -f "site/data/catalog.json" ]; then
    if ! diff -q data/catalog.json site/data/catalog.json > /dev/null 2>&1; then
        echo "BLOCKED: site/data/catalog.json is out of sync with data/catalog.json"
        echo "Fix: cp data/catalog.json site/data/catalog.json"
        exit 1
    fi
fi

echo "=== Pre-commit: all checks passed ==="
