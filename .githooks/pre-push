#!/bin/bash
# pre-push hook for amiport
# Runs expensive checks (build + test compilation) before pushing to origin.
# Catches build breakage before it hits CI.
#
# Install: git config core.hooksPath .githooks

set -e

echo "=== Pre-push: building shim library ==="
if ! make -C lib/posix-shim 2>&1 | tail -5; then
    echo "BLOCKED: Shim library failed to build."
    exit 1
fi

echo "=== Pre-push: compiling shim tests ==="
SHIM_OUTPUT=$(make -C tests/shim build 2>&1)
if [ $? -ne 0 ]; then
    echo "BLOCKED: Shim tests failed to compile:"
    echo "$SHIM_OUTPUT" | tail -10
    exit 1
fi

echo "=== Pre-push: deploying site to amiport.platesteel.net ==="
# Sync site/ to Dreamhost on every push. This ensures the live site
# always matches what's in git. Runs rsync with checksum mode.
if command -v rsync >/dev/null 2>&1; then
    rsync -az --checksum --delete \
        --exclude='.DS_Store' \
        site/ \
        bdgscotland@amiport.platesteel.net:amiport.platesteel.net/ \
        2>&1 | tail -5
    echo "Site deployed."
else
    echo "WARNING: rsync not found — site not deployed."
fi

echo "=== Pre-push: all checks passed ==="
