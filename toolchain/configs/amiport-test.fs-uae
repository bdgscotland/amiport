# FS-UAE configuration for testing amiport builds
#
# Usage:
#   make emu                        # launch with all built ports
#   fs-uae toolchain/configs/amiport-test.fs-uae   # launch directly
#
# Prerequisites:
#   brew install fs-uae
#   Place Kickstart 3.1 ROM at ~/Documents/FS-UAE/Kickstarts/kick31.rom
#   (Purchase from amigaforever.com or extract from real hardware)

amiga_model = A1200

# Kickstart 3.1 ROM — update path if yours is named differently
kickstart_file = $BASE/Kickstarts/kick3.1.rom

# System hard drive — bootable Workbench 3.1 installation
hard_drive_0 = $CONFIG/../../build/system
hard_drive_0_label = System
hard_drive_0_priority = 1

# Mount build output as WORK: — all compiled ports appear here
hard_drive_1 = $CONFIG/../../build/amiga
hard_drive_1_label = WORK

# Keyboard — use symbolic mapping so Mac keys match what's printed on them
keyboard_input_grab = 1
raw_input = 0

# 8MB Fast RAM — interactive tests (ITEST: blocks) spawn multiple CLI
# processes with 256KB stacks, which exhaust the A1200's 2MB Chip RAM
fast_memory = 8192

# Window settings
window_width = 720
window_height = 568

# Screenshots — saved to RESULTS dir by test-fsemu.sh
# Set via FSEMU_SCREENSHOTS_DIR env var at runtime
