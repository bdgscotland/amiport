#!/bin/bash
# m68k-amigaos-ar wrapper — invokes ar via Docker or native
REAL_AR=$(PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "$(dirname "$0")" | tr '\n' ':') which m68k-amigaos-ar 2>/dev/null)
if [ -n "$REAL_AR" ]; then exec "$REAL_AR" "$@"; fi
PROJECT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
IMAGE=""
if docker image inspect amigadev/m68k-amigaos-gcc &> /dev/null 2>&1; then IMAGE="amigadev/m68k-amigaos-gcc"
elif docker image inspect amiport/bebbo-gcc &> /dev/null 2>&1; then IMAGE="amiport/bebbo-gcc"
else echo "ERROR: No cross-compiler. Run 'make setup-toolchain'." >&2; exit 1; fi
exec docker run --rm -v "$PROJECT_DIR:/work" -w "/work$(pwd | sed "s|$PROJECT_DIR||")" "$IMAGE" m68k-amigaos-ar "$@"
