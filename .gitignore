# Build output
*.o
*.a
*.elf
*.adf
*.lha
*.lib
build/

# Compiled Amiga binaries (produced by make build)
examples/wc/wc
examples/head/head
examples/mini-find/mini-find
tests/shim/test_*
!tests/shim/test_*.c
!tests/shim/test_*.h

# Port packaging artifacts and generated reports
ports/*/*.lha
ports/*/*.zip
ports/*/TEST-REPORT.md

# Stray binaries in ported source dirs (compiled binaries go in ports/<name>/<name> only)
ports/*/ported/[a-z]*
!ports/*/ported/*.c
!ports/*/ported/*.h

# Aminet-generated readmes with version numbers (keep only <name>.readme)
ports/*/*-*.readme

# Test binaries (emu, console, net)
tests/emu/test_*
!tests/emu/test_*.c
!tests/emu/test_*.h
tests/console/test_*
!tests/console/test_*.c
tests/net/test_*
!tests/net/test_*.c
!tests/net/test_*.h

# Emulator staging directory (populated by make install-emu)
build/amiga/

# Toolchain
/opt/amiga/

# Docker
.docker-env

# Local environment (user identity, credentials)
.env
!.env.example

# Claude Code local settings
.claude/settings.local.json

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Node (defensive)
node_modules/

# Python (vamos/amitools)
__pycache__/
*.pyc
.venv/
venv/
gmon.out

# ADCD scraper intermediate files (regenerable)
docs/references/adcd/raw/

# Debug tools (downloaded from Aminet, not committed)
toolchain/debug-tools/

# Debug pipeline artifacts (generated per run)
enforcer.log
enforcer-hits.json
enforcer-mapped.json
*.map
