# Makefile for __TARGET__ (amiport)
include ../common.mk

TARGET      = __TARGET__
SOURCES     = ported/__TARGET__.c
VERSION     = __VERSION__
REVISION    = 1
DESCRIPTION = __DESCRIPTION__  # Max 40 chars, ASCII only (Aminet requirement)
AUTHOR      = __AUTHOR__

# Override if not util/cli (e.g., util/misc, text/edit)
# AMINET_CAT = util/cli

# Add extra libraries for non-CLI ports:
# Category 3 (console UI): LDFLAGS += -lamiport-console
# Category 4 (network):    LDFLAGS += -lamiport-net

# Uncomment if the port has struct-by-value returns > 8 bytes (crash-patterns #16):
# CFLAGS += -O0  # bebbo-gcc corrupts large struct returns at -O1/-O2

# For ports with 5+ source files, consider per-file compilation (each .c -> .o,
# then link) instead of single-command compilation. This enables per-file
# optimization levels (e.g., -O0 for one file, -O2 for the rest) and faster
# rebuild iterations. Example:
#   OBJECTS = ported/main.o ported/util.o ported/parser.o
#   ported/parser.o: ported/parser.c
#   	$(CC) $(CFLAGS) -O0 -c -o $@ $<   # -O0 for this file only
#   $(TARGET): $(OBJECTS) $(SHIM_LIB)
#   	$(CC) $(CFLAGS) -o $(TARGET) $(OBJECTS) $(LDFLAGS)

.PHONY: all clean test package compare

test: $(TARGET)
	@echo "=== Testing $(TARGET) ==="
	@# TODO: Add test commands using vamos
	@# Example: echo "input" | ../../toolchain/scripts/vamos -C "" ./$(TARGET) -flags
	@echo "=== $(TARGET) tests complete ==="

compare: $(TARGET)
	@echo "=== Comparing native vs Amiga: $(TARGET) ==="
	$(NATIVE_CC) $(NATIVE_CFLAGS) -o $(TARGET)_native original/__TARGET__.c
	@# TODO: Add comparison commands
	@rm -f $(TARGET)_native
