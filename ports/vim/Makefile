# Makefile for vim 9.1 (amiport)
#
# Based on upstream Make_ami.mak, adapted for AmigaOS 3.x with bebbo-gcc.
# Vim has built-in Amiga support (os_amiga.c) — we adapt the build config,
# not the OS layer. Changes are minimal and upstreamable.
include ../common.mk

TARGET      = vim
VERSION     = 9.1
REVISION    = 1
DESCRIPTION = Vi IMproved text editor
AUTHOR      = Bram Moolenaar et al.
CATEGORY    = 3
AMINET_CAT  = text/edit

# --- Override common.mk defaults for vim ---
# Vim needs -m68020 (too large/slow for 68000), gnu99 (pervasive C99),
# and does NOT use console-shim (has its own terminal I/O in os_amiga.c)
CFLAGS = -Os -noixemul -m68020 -std=gnu99 -Wall -Wno-attributes \
	-I../../lib/posix-shim/include -Iported -Iported/proto

# Feature selection: FEAT_NORMAL gives syntax, folds, windows, vimscript, vim9
# Without FEAT_HUGE we avoid FEAT_CSCOPE (needs fork), FEAT_TERMINAL (needs pty)
CFLAGS += -DFEAT_NORMAL

# Amiga build flags (from upstream Make_ami.mak)
CFLAGS += -DAMIGA -DNO_ARP -DUSE_TMPNAM -DNEW_SHELLSIZE
# 68k is big-endian (blowfish.c checks this directly).
CFLAGS += -DWORDS_BIGENDIAN

# POSIX feature detection for libnix
# Note: HAVE_STDLIB_H, HAVE_STRING_H, HAVE_FCNTL_H, HAVE_STRCSPN,
# HAVE_STRICMP, HAVE_STRNICMP, HAVE_STRFTIME, HAVE_SETENV, HAVE_MEMSET,
# HAVE_QSORT, HAVE_DATE_TIME are already defined in os_amiga.h.
# HAVE_STAT_H is intentionally omitted: it triggers <stat.h> (non-existent);
# sys/stat.h is already included via the other ifdef paths in vim.h.
CFLAGS += -DHAVE_STDARG_H -DHAVE_TGETENT -DHAVE_TERMCAP -DHAVE_ERRNO_H

# vamos stack must match __stack cookie (256KB)
VAMOS_STACK = 256
VAMOS_MEM = 8192

# Linker flags — amiport shim for POSIX I/O, libm for float.c
LDFLAGS = -noixemul -m68020 -L../../lib/posix-shim -lamiport -lm

# --- Source files (from upstream Make_ami.mak) ---
VPATH = ported:ported/xdiff

CORE_SRC = \
	vim_stubs.c \
	alloc.c arabic.c arglist.c autocmd.c beval.c blob.c blowfish.c \
	buffer.c bufwrite.c change.c charset.c cindent.c clientserver.c \
	clipboard.c cmdhist.c cmdexpand.c crypt.c crypt_zip.c debugger.c \
	dict.c diff.c digraph.c drawline.c drawscreen.c edit.c eval.c \
	evalbuffer.c evalfunc.c evalvars.c evalwindow.c ex_cmds.c ex_cmds2.c \
	ex_docmd.c ex_eval.c ex_getln.c fileio.c filepath.c findfile.c \
	float.c fold.c getchar.c hardcopy.c hashtab.c help.c highlight.c \
	if_cscope.c indent.c insexpand.c json.c list.c locale.c logfile.c \
	main.c mark.c map.c match.c mbyte.c memfile.c memline.c menu.c \
	message.c misc1.c misc2.c mouse.c move.c normal.c ops.c option.c \
	optionstr.c os_amiga.c popupmenu.c popupwin.c quickfix.c regexp.c \
	register.c screen.c scriptfile.c search.c session.c sha256.c sign.c \
	spell.c spellfile.c spellsuggest.c strings.c syntax.c tag.c term.c \
	termlib.c testing.c textformat.c textobject.c textprop.c time.c \
	typval.c ui.c undo.c usercmd.c userfunc.c version.c viminfo.c \
	vim9class.c vim9cmds.c vim9compile.c vim9execute.c vim9expr.c \
	vim9instr.c vim9script.c vim9type.c window.c

XDIFF_SRC = \
	xdiffi.c xemit.c xhistogram.c xpatience.c xprepare.c xutils.c

ALL_SRC = $(CORE_SRC) $(XDIFF_SRC)

# Object files go into ported/ to keep things clean
CORE_OBJ = $(addprefix ported/,$(CORE_SRC:.c=.o))
XDIFF_OBJ = $(addprefix ported/xdiff/,$(XDIFF_SRC:.c=.o))
ALL_OBJ = $(CORE_OBJ) $(XDIFF_OBJ)

# Vim also needs auto/pathdef.c — we generate it
PATHDEF_OBJ = ported/pathdef.o

# --- Build rules ---
.PHONY: all clean test package

all: $(TARGET)

$(TARGET): $(ALL_OBJ) $(PATHDEF_OBJ) $(SHIM_LIB)
	$(CC) -o $@ $(ALL_OBJ) $(PATHDEF_OBJ) $(LDFLAGS)

# Compile core .c files
ported/%.o: ported/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Compile xdiff .c files
ported/xdiff/%.o: ported/xdiff/%.c
	$(CC) $(CFLAGS) -c -o $@ $<

# Generate pathdef.c (vim expects auto/pathdef.c with compile-time paths)
ported/pathdef.c:
	@echo '/* pathdef.c — generated by amiport Makefile */' > $@
	@echo '#include "vim.h"' >> $@
	@echo 'char_u *default_vim_dir = (char_u *)"S:vim";' >> $@
	@echo 'char_u *default_vimruntime_dir = (char_u *)"S:vim/runtime";' >> $@
	@echo 'char_u *all_cflags = (char_u *)"m68k-amigaos-gcc $(CFLAGS)";' >> $@
	@echo 'char_u *all_lflags = (char_u *)"$(LDFLAGS)";' >> $@
	@echo 'char_u *compiled_user = (char_u *)"amiport";' >> $@
	@echo 'char_u *compiled_sys = (char_u *)"AmigaOS 3.x";' >> $@

ported/pathdef.o: ported/pathdef.c
	$(CC) $(CFLAGS) -c -o $@ $<

test: $(TARGET)
	@echo "=== Testing $(TARGET) ==="
	@echo "NOTE: vim uses -m68020 and cannot be tested with vamos (68000 only)."
	@echo "Use make test-fsemu TARGET=ports/vim for FS-UAE testing."
	@echo "=== $(TARGET) tests complete ==="

clean:
	rm -f ported/*.o ported/xdiff/*.o ported/pathdef.c $(TARGET) $(TARGET).map
