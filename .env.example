# amiport — Local configuration
#
# Copy this file to .env and fill in your details:
#   cp .env.example .env
#
# This file is gitignored and local to your machine.

# Your email for Aminet uploads (partially obfuscated on the site)
AMINET_EMAIL="you@example.com"

# Your name (credited as porter in Aminet readme)
AMINET_NAME="Your Name"
